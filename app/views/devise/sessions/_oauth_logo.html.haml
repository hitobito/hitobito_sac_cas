-# We don't want to display any default logo when the oauth app does not have a logo uploaded.

-if oauth_app.present? && upload_exists?(oauth_app, :logo)
    .oauth-application-logo
        = image_tag(upload_url(oauth_app, :logo, variant: :thumb), size: '64x64')