= standard_form(entry, url: group_event_report_path(@group, @event), method: :put) do |f|
  = render "form_tabs"

  .tab-content
    = tab_content(:status, default_active: true) do
      = render "status_fields", f: f
    = tab_content(:participations) do
      = render "participation_fields", f: f
    = tab_content(:price_summary) do
      = render "price_summary_fields", f: f

  = form_buttons(f, cancel_url: group_event_path(@group, @event))
