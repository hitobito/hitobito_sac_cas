%aside.card
  .card-body
    %h2.mb-2.card-title=t('.summary_title')
    .card-text
      %table.table.table-borderless
        %tbody
          %tr
            %td=t('.price_total')
            %td.text-end=number_to_currency(price, unit: 'CHF', format: '%u %n')
      - if @event.price_description?
        .alert.alert-info=@event.price_description

- if @event.contact
  = render 'event/participations/tours/contact_data_aside'
