%p= t('.general_info')

.well
  %h3= t('.detail_info_header')

  - link = link_to(t('.subsidy_link_label'), t('.subsidy_link_href'), target: :_blank)
  - amount = number_to_currency(entry.event.price_subsidized, unit: 'CHF', format: '%u %n')
  %p= t('.detail_info_text', link: link, amount: amount).html_safe
