= entry_form(buttons_bottom: false) do |f|
  = f.labeled_input_fields :label, :short_description, :description, :order
  %div{ data: { controller: "field-visibility", "field-visibility-observed-field-id-value": "event_activity_parent_id", "field-visibility-hide-when-present-value": "true", "field-visibility-clear-container-inputs-on-hide-value": "true" } }
    %div{ class: ("hidden" if !entry.new_record? || entry.parent_id), data: { "field-visibility-target": "container" } }
      = f.labeled_short_field :color, help_inline: t('.help_inline_color')
  = f.labeled_input_field :parent_id if entry.new_record?
  %div{ data: { controller: "field-visibility", "field-visibility-observed-field-id-value": "event_activity_parent_id", "field-visibility-show-when-present-value": "true", "field-visibility-clear-container-inputs-on-hide-value": "true" } }
    %div{ class: ("hidden" if entry.new_record? || entry.parent_id.nil?), data: { "field-visibility-target": "container" } }
      = f.labeled_input_field :technical_requirement_id, list: Event::TechnicalRequirement.main
