= standard_form(entry, url: state_group_event_path(params[:group_id], params[:id], {state: :review}), method: :put) do |f|
  .row
    .col-12
      = submit_button(f, t('.destroy_and_review'), name: :button, value: :destroy)
      = submit_button(f, t('.keep_and_review'), name: :button, value: :keep)
      = cancel_link('#')
