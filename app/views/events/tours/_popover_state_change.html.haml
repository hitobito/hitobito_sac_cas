.alert.alert-info=info_alert

= standard_form(entry, url: state_group_event_path(params[:group_id], params[:id], {state: next_state}), method: :put) do |f|
  = f.labeled_input_field :internal_comment, label_class: "col-3"

  = yield(f)

  = render "events/tours/popover_email_option", f: f, receiver_options: receiver_options, none_selected: none_selected

  = button_toolbar(f, toolbar_class: "bottom offset-xl-3") do
    = submit_button(f, t("global.button.confirm"), name: :button)
    = cancel_link("#")
