.alert.alert-warning=t(".alert_warning", event_name: entry.to_s, event_id: entry.id)

= standard_form(entry, url: state_group_event_path(params[:group_id], params[:id], {state: :approved}), method: :put) do |f|
  = button_toolbar(f, toolbar_class: "bottom") do
    = submit_button(f, t(".self_approve"), name: :button)
    = cancel_link("#")
