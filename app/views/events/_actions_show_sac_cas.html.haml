- if entry.states? && can?(:update, entry)
  - if entry.course?
    = Dropdown::Events::Courses::State.new(self, entry)
  - elsif entry.tour?
    = Dropdown::Events::Tours::State.new(self, entry)
-if entry.course? && can?(:create, entry) && entry.any_email_possible?
  = Dropdown::Events::Courses::MailDispatch.new(self, entry, @group)
- if entry.course? && can?(:create, entry)
  = action_button(t(".attach_key_data_sheets"), group_event_key_data_sheets_path(@group, entry), :file_pdf, method: :post)
- if entry.tour? && can?(:update, entry)
  = action_button(t(".approval"), edit_group_event_approval_path(@group, entry), :clipboard_check)
- if entry.tour? && can?(:update, entry) && entry.reportable?
  = action_button(t(".report"), edit_group_event_report_path(@group, entry), :chart_bar)