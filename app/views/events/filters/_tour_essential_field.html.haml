.row.mb-2
  = fields.label(param, ti(key), class: "col-form-label col-md-3 col-xl-2")
  .col-md-9.mw-63ch
    - entries = klass.list.without_deleted
    = fields.select(param, [], {},
      class: "form-select form-select-sm w-100",
      multiple: true,
      data: { controller: 'tom-select',
      tom_select_options_value: tour_essentials_nested_select_options(entries),
      tom_select_selected_value: Array(filter.chain.dig(:tour_essentials, param)).to_json,
      tom_select_render_option_function_value: SacCas::EventsHelper::TOM_SELECT_COLORED_OPTION,
      tom_select_no_results_value: I18n.t('global.no_list_entries'),
      })
