.row.mb-2
  = fields.label(:fitness_requirement_id, ti('.fitness_requirements'), class: "col-form-label col-md-3 col-xl-2")
  .col-md-9.mw-63ch
    - entries = Event::FitnessRequirement.list.without_deleted
    = fields.select(:fitness_requirement_id, [], {},
      class: "form-select form-select-sm w-100",
      multiple: true,
      data: { controller: 'tom-select',
      tom_select_options_value: fitness_requirements_select_options(entries),
      tom_select_selected_value: Array(filter.chain.dig(:tour_essentials, :fitness_requirement_id)).to_json,
      tom_select_no_results_value: I18n.t('global.no_list_entries'),
      })
