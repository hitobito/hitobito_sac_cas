#alps_recipients_form
  .alert.alert-info= t(".info_html")

  = standard_form(model, url: group_export_alps_recipients_path(group), method: :post) do |f|
    = f.error_messages

    = f.labeled_date_field(:reference_date, label_class: "col-3")
    = f.labeled_date_field(:new_entries_from, label_class: "col-3")

    = form_buttons(f, submit_label: t('.download'), cancel_url: "#", toolbar_class: "offset-3")
